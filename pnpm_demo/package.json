{
  "name": "pnpm_demo",
  "version": "1.0.0",
  "description": "",
  "main": "dist/bundle.js",
  "type": "module",
  "scripts": {
    "typecheck": "pnpm exec tsc --noEmit",
    "build": "pnpm run typecheck && pnpm exec esbuild src/index.ts --bundle --platform=browser --format=iife --global-name=DemoApp --outfile=dist/bundle.js",
    "build:cases": "node build-cases.mjs",
    "run:node": "node dist/bundle.js",
    "test:cases:node": "pnpm run build:cases && node run-cases-node.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
